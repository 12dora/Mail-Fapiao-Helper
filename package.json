{
  "name": "mail-fapiao-helper",
  "version": "0.0.1",
  "description": "从邮箱抓取发票邮件、自动下载并归档 PDF",
  "private": true,
  "type": "module",
  "bin": {
    "mfh": "./dist/index.js"
  },
  "main": "./dist/electron/main.js",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win --x64",
    "electron": "npm run build && electron .",
    "dev": "tsc -p . --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p . --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.19.41",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.mailfapiao.helper",
    "productName": "发票助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "gui-design/**/*",
      "icon/**/*",
      "config.example.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/efapiao",
        "to": "vendor/efapiao"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon/icon.icns",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "icon/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "icon/icon.ico",
      "uninstallerIcon": "icon/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
