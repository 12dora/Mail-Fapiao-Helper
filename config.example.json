{
  "imap": {
    "host": "imap.example.com",
    "port": 993,
    "user": "me@example.com",
    "pass": "***",
    "tls": true,
    "mailbox": []
  },
  "filter": {
    "keywords": ["发票"],
    "matchSubject": true,
    "matchBody": true,
    "sinceDays": 30,
    "since": null,
    "until": null
  },
  "paths": {
    "samples": "./samples/raw",
    "invoices": "./invoices",
    "pending": "./pending"
  },
  "output": {
    "dir": "./invoices",
    "pendingDir": "./pending",
    "csv": "./invoices.csv"
  },
  "rename": {
    "rule": "{seller}-{amount}.pdf",
    "fallback": "{date}-{messageId}.pdf",
    "applyAfterOcr": false,
    "organizeByType": false,
    "typeDirRule": "{documentType}",
    "organizedDir": "./invoices/organized"
  },
  "ocr": {
    "enabled": true,
    "provider": "efapiao",
    "binaryPath": "auto",
    "timeoutMs": 120000,
    "resultsCsv": "./invoices/ocr/ocr-results.csv",
    "credentials": { "apiKey": "", "secretKey": "" }
  },
  "llm": {
    "enabled": false,
    "provider": "anthropic",
    "model": "claude-haiku-4-5-20251001",
    "apiKey": ""
  },
  "playwright": {
    "headless": true,
    "timeoutMs": 30000
  },
  "network": {
    "retries": 3,
    "retryDelayMs": 1000
  }
}
